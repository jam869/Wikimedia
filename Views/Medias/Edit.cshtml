@model Models.Media
@{
    ViewBag.Action = "Edit";
    Html.RenderPartial("MediaForm");
    ViewBag.PageTitle = "Modification";
}

@section Scripts {
    <script>
        $(() => {
            initFormValidation();
            addConflictValidation("/Medias/CheckConflict", 'YoutubeId', 'submit');

            $("#YoutubeId").on("input", function () {
                let inputVal = $(this).val().trim();
                let youtubeId = inputVal;

                let regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
                let match = inputVal.match(regExp);

                if (match && match[2].length === 11) {
                    youtubeId = match[2];
                    $("#YoutubeId").val(youtubeId);
                }

               
                if (youtubeId.length > 0) {
                    $("#previewThumbnail").attr("src", `https://img.youtube.com/vi/${youtubeId}/mqdefault.jpg`);
                } else {
                    $("#previewThumbnail").attr("src", "");
                }
            })
        })
    </script>
}