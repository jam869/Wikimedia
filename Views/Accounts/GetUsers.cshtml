@model IEnumerable<Models.User>

@foreach (var user in Model)
{
    <div class="userLayout">
        <div class="userInnerLayout">
            @* Affichage de l'avatar et du nom *@
            @Helper.AvatarUser(user, "UserSmallAvatar")

            @* Icônes de gestion utilisant les classes attendues par ManageUsers.cshtml *@
            <div class="userCommandPanel">

                @* Changer l'accès (ex: promouvoir à admin) *@
                <i class="setUserAccessCmd fa fa-user-plus" userId="@user.Id" access="2" title="Promouvoir"></i>

                @* Bloquer / Débloquer *@
                <i class="blockCmd fa @(user.Blocked ? "fa-ban text-danger" : "fa-check-circle text-success")"
                   userId="@user.Id" title="@(user.Blocked ? "Débloquer" : "Bloquer")"></i>

                @* Supprimer *@
                <i class="deleteCmd fa fa-user-times text-danger" userId="@user.Id" title="Effacer @user.Name"></i>

                @* Forcer la vérification *@
                @if (!user.Verified)
                {
                    <i class="forceVerifyCmd fa fa-envelope-check text-warning" userId="@user.Id" title="Vérifier manuellement"></i>
                }
            </div>
        </div>
    </div>
}