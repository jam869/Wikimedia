@model Models.User
@{
    Html.RenderPartial("ProfilForm");
    ViewBag.PageTitle = "Nouveau compte";
}

@section Scripts {
    <script src="/Scripts/image-control.js"></script>

    <script>
        var showPassword = false;

        $(() => {
            new Session(120);
            initFormValidation();

            addConflictValidation("/Accounts/EmailAvailable", 'Email', 'submit');

            $("#toggleShowPassword").hide();
            $("#toggleShowPassword").click(() => { toggleShowPassword(); });

            $("#Password").keyup(() => {
                if ($("#Password").val() == "")
                    $("#toggleShowPassword").hide();
                else
                    $("#toggleShowPassword").show();
            });
        });

        function toggleShowPassword() {
            showPassword = !showPassword;
            let type = showPassword ? 'text' : 'password';
            $("#Password").attr("type", type);
            $("#ConfirmPassword").attr("type", type);
            $("#toggleShowPassword").toggleClass("fa-eye-slash fa-eye");
        }
    </script>
}